# Copy to .env (gitignored). NEVER commit real values.

# Dashboard base URL (REST API + /events WebSocket).
HERMES_DASHBOARD_URL=http://127.0.0.1:9119

# Kanban DB path (read-only). Default: ~/.hermes/kanban.db
# IMPORTANT: run the backend INSIDE WSL so ~ resolves to /home/<user>.
# Running from Windows resolves ~ to C:\Users\<user>, where no Hermes DB exists.
# (A \\wsl$ UNC path technically reads but is WAL-over-9p and unreliable — don't.)
# See DISCOVERY.md (host reality) and PLAN.md ground truth #11.
HERMES_KANBAN_DB=~/.hermes/kanban.db

# Board slug to read/drive.
HERMES_KANBAN_BOARD=default

# Dashboard session token. Required for authenticated REST writes — in Hermes
# v0.17 the kanban REST API at /api/plugins/ is GATED (see DISCOVERY.md §2),
# NOT unauthenticated. Co-launch the dashboard with the SAME value:
#   HERMES_DASHBOARD_SESSION_TOKEN=<secret> hermes dashboard --no-open --skip-build
HERMES_DASHBOARD_SESSION_TOKEN=

# Data source: "auto" (default) picks KanbanAdapter if the DB above exists,
# else falls back to an empty stub. Set to "synthetic" to run the public-demo
# adapter instead — no real Hermes attached, plausible agents/tasks/events on
# a loop, and act() always declines (read-only). Used for the public demo
# deploy (see README "Public demo").
HERMES_DATA_SOURCE=auto